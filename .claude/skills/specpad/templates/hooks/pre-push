#!/usr/bin/env bash
#
# SpecPad pre-push check.
# Canonical copy: skill/specpad/templates/hooks/pre-push (installed by `specpad init`).
# Install per repo with:  git config core.hooksPath .githooks
#
#   HARD-BLOCK : a pushed commit with no `Job:` trailer.
#   WARN       : a pushed commit that changes code but touches no SRS/VTP — run a
#                SpecPad requirement audit, or add a `Spec: none <reason>` trailer
#                (e.g. a refactor or comment-only change) to acknowledge it.
#   Bypass all : SPECPAD_SKIP=1 git push    (emergencies only)
#
# Workflow-agnostic: merge commits are skipped, and history before SpecPad was
# adopted (the first commit that added docs/specpad/) is never policed — so this
# is safe to install on an existing repo and on any branching model.

[ "${SPECPAD_SKIP:-0}" = "1" ] && exit 0

specdir="docs/specpad"
[ -d "$specdir" ] || exit 0   # not a SpecPad project — nothing to enforce

ZERO="0000000000000000000000000000000000000000"
adoption=$(git log --diff-filter=A --reverse --format=%H -- "$specdir" 2>/dev/null | head -1)

block=0
warn=0

check_commit() {
  sha="$1"
  subject=$(git show -s --format='%s' "$sha")
  job=$(git show -s --format='%(trailers:key=Job,valueonly)' "$sha" | tr -d '[:space:]')
  if [ -z "$job" ]; then
    echo "  ✗ ${sha:0:9}  $subject" >&2
    echo "      no Job: trailer — every commit must reference a job." >&2
    block=1
  fi
  files=$(git diff-tree --no-commit-id --name-only -r "$sha")
  code=$(printf '%s\n' "$files" | grep -vE "(^|/)$specdir/|\.md$" | sed '/^$/d')
  spec=$(printf '%s\n' "$files" | grep -E "$specdir/.*\.(srs|vtp)\.json$" || true)
  spec_none=$(git show -s --format='%(trailers:key=Spec,valueonly)' "$sha" | tr -d '[:space:]')
  if [ -n "$code" ] && [ -z "$spec" ] && [ -z "$spec_none" ]; then
    echo "  ⚠ ${sha:0:9}  $subject" >&2
    echo "      changed code but no SRS/VTP — run a SpecPad requirement audit," >&2
    echo "      or add a 'Spec: none <reason>' trailer (e.g. refactor/comments)." >&2
    warn=1
  fi
}

while read -r local_ref local_sha remote_ref remote_sha; do
  [ "$local_sha" = "$ZERO" ] && continue            # branch deletion
  case "$local_ref" in refs/tags/*) continue ;; esac # tag push points at already-pushed commits
  if [ "$remote_sha" != "$ZERO" ]; then
    base="$remote_sha"
  else
    base="$adoption"                                 # new branch: floor at adoption
  fi
  if [ -n "$base" ]; then range="$base..$local_sha"; else range="$local_sha"; fi
  for sha in $(git rev-list --no-merges "$range" 2>/dev/null); do
    check_commit "$sha"
  done
done

if [ "$block" = "1" ]; then
  echo "" >&2
  echo "SpecPad: push blocked — fix the commit(s) above (set an active job, then amend/rebase)." >&2
  echo "         Emergency bypass:  SPECPAD_SKIP=1 git push" >&2
  exit 1
fi
[ "$warn" = "1" ] && echo "SpecPad: pushed with the warning(s) above (requirement audit recommended)." >&2
exit 0
