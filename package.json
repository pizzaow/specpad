{
  "name": "specpad",
  "version": "0.1.0",
  "description": "SpecPad - AI-governed, browser-based editor for software requirements (SRS), verification tests (VTP), and a project index. Files are structured JSON edited via a Claude Code skill and a hosted visual editor.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"site/src/**/*.ts\"",
    "dev:site": "vite --config site/vite.config.ts",
    "build:site": "tsx site/src/generate-reference.ts && vite build --config site/vite.config.ts",
    "capture:screenshots": "NODE_PATH=$(npm root -g) node site/scripts/capture-screenshots.mjs"
  },
  "keywords": [
    "specpad",
    "requirements",
    "srs",
    "vtp",
    "testing",
    "traceability",
    "claude-code-skill"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pizzaow/specpad.git"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "bootstrap": "^3.4.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^18.15.11",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^5.59.0",
    "@typescript-eslint/parser": "^5.59.0",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^8.38.0",
    "eslint-plugin-react": "^7.32.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^25.0.1",
    "less": "^4.1.3",
    "tsx": "^4.22.4",
    "typescript": "^5.0.4",
    "vite": "^5.4.21",
    "vitest": "^2.1.9"
  }
}
